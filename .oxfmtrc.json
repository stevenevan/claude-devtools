{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "sortTailwindcss": {},
  "sortImports": {
    "groups": [
      "side_effect",
      "builtin",
      "react-packages",
      "external",
      "internal",
      "parent",
      ["sibling", "index"],
      "type"
    ],
    "customGroups": [
      {
        "groupName": "react-packages",
        "elementNamePattern": ["react", "react-dom", "react-dom/**"]
      }
    ],
    "internalPattern": ["@main/**", "@renderer/**", "@shared/**", "@preload/**"],
    "newlinesBetween": true
  },
  "overrides": [
    {
      "files": ["*.json", "*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "dist-electron/",
    "build/",
    "out/",
    "node_modules/",
    "pnpm-lock.yaml",
    "*.min.js",
    "*.min.css",
    "*.config.js",
    "*.config.ts",
    ".idea/",
    ".vscode/",
    ".DS_Store",
    "*.log"
  ]
}
