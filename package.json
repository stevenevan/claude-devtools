{
  "name": "claude-devtools",
  "type": "module",
  "version": "0.4.8",
  "description": "Desktop app that visualizes Claude Code session execution — explore conversations, track context usage, and analyze tool calls",
  "license": "MIT",
  "author": {
    "name": "claude-devtools contributors",
    "email": "matt1398@users.noreply.github.com"
  },
  "homepage": "https://github.com/matt1398/claude-devtools",
  "repository": {
    "type": "git",
    "url": "https://github.com/matt1398/claude-devtools.git"
  },
  "bugs": {
    "url": "https://github.com/matt1398/claude-devtools/issues"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:frontend": "vite dev",
    "build": "tauri build",
    "build:frontend": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build:frontend",
    "fix": "bun run lint:fix && bun run format",
    "quality": "bun run check && bun run format:check && bunx knip",
    "test:chunks": "tsx test/test-chunk-building.ts",
    "test:semantic": "tsx test/test-semantic-steps.ts",
    "test:noise": "tsx test/test-noise-filtering.ts",
    "test:task-filtering": "tsx test/test-task-filtering.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:critical": "vitest run --coverage --config vitest.critical.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "mdast-util-to-hast": "^13.2.1",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.6",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "happy-dom": "^20.8.9",
    "rollup-plugin-visualizer": "^5.14.0",
    "vitest-axe": "^1.0.0",
    "knip": "^6.0.6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
