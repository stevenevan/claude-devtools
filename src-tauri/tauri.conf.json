{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/refs/tags/v2.14.0/nicegui/static/tauri.conf.json",
  "productName": "claude-devtools",
  "version": "0.4.8",
  "identifier": "com.claudedevtools.desktop",
  "build": {
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite dev",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "claude-devtools",
        "width": 1400,
        "height": 900,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "sidecar/*": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "targets": ["dmg", "nsis", "appimage", "deb"]
  }
}
